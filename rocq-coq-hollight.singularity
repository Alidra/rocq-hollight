Bootstrap: docker
From: abdelghanialidra/rocq-hol-light:0.0.1

%help
    to build a .sif image from this file use
    sudo singularity build rocq-hol-light_0.0.1.sif rocq-coq-hollight.singularity
    
%environment
    HOME=/home/opam

%runscript
    exec /bin/bash "$@"

%post
    echo "setting home directory"
    export HOME=/home/opam
    echo "initializing opam"
    opam init
    eval $(opam env)
    apt install -y htop
    chmod 777 $HOME
    echo "End of build phase"